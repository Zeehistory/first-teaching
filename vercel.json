{
  "buildCommand": "npm run build",
  "outputDirectory": "dist/public",
  "routes": [
    { "src": "^/api/ai/ask$", "dest": "api/ai/ask.ts" },
    { "src": "^/$", "dest": "api/index.ts" },
    { "src": "^/login$", "dest": "api/index.ts" },
    { "src": "^/glossary$", "dest": "api/index.ts" },
    { "src": "^/v/.*$", "dest": "api/index.ts" }
  ],
  "functions": {
    "api/ai/ask.ts": {
      "includeFiles": [
        "server/data/knowledge-index.json",
        "api/_lib/**"
      ]
    }
  }
}
